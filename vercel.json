{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/chart.ts": {
      "includeFiles": "{node_modules/puppeteer-core,node_modules/chrome-aws-lambda,node_modules/@opentelemetry}/**/*"
    }
  },
  "rewrites": [
    { "source": "/chart/:path*", "destination": "/api/chart" },
    { "source": "/dt/:path*", "destination": "https://js-cdn.dynatrace.com/jstag/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
