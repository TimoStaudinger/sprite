# Dynatrace Configuration
# ----------------------

# Frontend RUM — Dynatrace JavaScript agent URL
# Get this from: Dynatrace > Deploy Dynatrace > Start monitoring > JavaScript
# Example: https://{tenant-id}.live.dynatrace.com/rux/...
VITE_DT_RUM_SCRIPT_URL=

# Backend tracing — Dynatrace OTLP ingestion endpoint
# Example: https://{tenant-id}.live.dynatrace.com/api/v2/otlp
DT_OTLP_ENDPOINT=

# Dynatrace API token — requires "openTelemetryTrace.ingest" scope
DT_API_TOKEN=
